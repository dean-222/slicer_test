             </property>
             <property name="styleSheet">
              <string>font-weight: bold;</string>
             </property>
            </widget>
           </item>
           <item row="0" column="1">
            <widget class="QLineEdit" name="selectedNameValue">
             <property name="readOnly">
              <bool>true</bool>
             </property>
             <property name="text">
              <string>None (Select a row in table)</string>
             </property>
             <property name="styleSheet">
              <string>background-color: #f5f5f5; border: none; font-weight: bold; color: #555;</string>
             </property>
            </widget>
           </item>
           <item row="1" column="0">
            <widget class="QLabel" name="positionLabel">
             <property name="text">
              <string>Position (X, Y, Z):</string>
             </property>
            </widget>
           </item>
           <item row="1" column="1">
            <widget class="QLineEdit" name="positionValue">
             <property name="readOnly">
