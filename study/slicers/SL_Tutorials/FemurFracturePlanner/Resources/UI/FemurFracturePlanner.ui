             </property>
             <property name="text">
              <string>N/A</string>
             </property>
             <property name="styleSheet">
              <string>background-color: #fff3e0; border: 1px solid #ffcc80; border-radius: 3px; font-family: Courier New; font-size: 11pt; font-weight: bold; color: #e65100; padding: 3px;</string>
             </property>
            </widget>
           </item>
          </layout>
         </widget>
        </item>
        <item>
         <layout class="QHBoxLayout" name="managerButtonsHLayout">
          <item>
           <widget class="QPushButton" name="refreshManagerButton">
            <property name="text">
             <string>🔄 Refresh List</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QPushButton" name="clearModelsButton">
            <property name="text">
             <string>🗑️ Clear All Fragments</string>
